@{ Layout = null; ViewData["Title"] = "Login"; }
<!DOCTYPE html>
<html><head><meta charset="utf-8"/><title>Login - Inventory</title>
<link rel="stylesheet" href="~/css/site.css"/></head>
<body>
<div class="login-wrap">
    <form method="post" class="login-card">
        <h1>📦 Inventory</h1>
        @if (ViewBag.Error != null) { <div class="error">@ViewBag.Error</div> }
        <div class="row"><label>Email</label><input name="email" value="admin@inventory.local" required/></div>
        <div class="row"><label>Password</label><input type="password" name="password" value="admin123" required/></div>
        <button class="btn btn-primary" style="width:100%">Sign in</button>
        <p class="muted" style="margin-top:1rem;text-align:center">Default: admin@inventory.local / admin123</p>
    </form>
</div>
</body></html>
