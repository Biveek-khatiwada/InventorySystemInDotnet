@model Inventory.ViewModels.SaleVm
@{ ViewData["Title"] = "New Sale";
   var customers = ViewBag.Customers as List<Inventory.Models.Customer>;
   var products = ViewBag.Products as System.Collections.IEnumerable; }
<h1>New Sale</h1>
@if (!ViewData.ModelState.IsValid) {
    <div class="error">@string.Join("; ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))</div>
}
<form method="post" id="saleForm">
    <div class="form" style="max-width:none">
        <div class="row"><label>Customer (optional)</label>
            <select asp-for="CustomerId">
                <option value="0">— Walk-in customer —</option>
                @foreach (var c in customers!) { <option value="@c.Id">@c.Name</option> }
            </select>
        </div>
    </div>

    <table class="items-table">
        <thead><tr><th style="width:45%">Product</th><th style="width:15%">Quantity</th>
            <th style="width:18%">Price</th>
            <th style="width:15%" class="num">Line Total</th><th></th></tr></thead>
        <tbody></tbody>
    </table>
    <div style="margin-top:.5rem"><button type="button" class="btn btn-secondary add-row">+ Add Item</button></div>
    <div class="totals">Total: <span class="grand-total" style="margin-left:.5rem">0.00</span></div>

    <div class="actions" style="margin-top:1rem">
        <button class="btn btn-primary">Save Sale</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
<script>
const products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products,
    new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
LineItems.init(document.getElementById('saleForm'), products, { includeSales: false });
</script>
