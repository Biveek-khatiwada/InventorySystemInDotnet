@model IEnumerable<Inventory.Models.UnitOfMeasure>
@{ ViewData["Title"] = "Unit of Measure"; }
<div class="toolbar"><h1>Unit of Measure</h1><a class="btn btn-primary" asp-action="Create">+ New</a></div>
<table>
<thead><tr><th>Name</th><th>Code</th><th>Description</th><th>Status</th><th>Created By</th><th></th></tr></thead>
<tbody>
@foreach (var x in Model) {
<tr>
    <td>@x.Name</td>
    <td>@x.Code</td>
    <td>@x.Description</td>
    <td><span class="badge @(x.Status == Inventory.Models.Status.Active ? "active" : "inactive")">@x.Status</span></td>
    <td>@x.User?.Name</td>
    <td><a asp-action="Edit" asp-route-id="@x.Id">Edit</a></td>
</tr>}
</tbody></table>
