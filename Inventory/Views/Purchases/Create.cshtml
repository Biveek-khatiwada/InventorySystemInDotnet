@model Inventory.ViewModels.PurchaseVm
@{ ViewData["Title"] = "New Purchase";
   var vendors = ViewBag.Vendors as List<Inventory.Models.Vendor>;
   var products = ViewBag.Products as System.Collections.IEnumerable; }
<h1>New Purchase</h1>
@if (!ViewData.ModelState.IsValid) {
    <div class="error">@string.Join("; ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))</div>
}
<form method="post" id="purchaseForm">
    <div class="form" style="max-width:none">
        <div class="row"><label>Vendor</label>
            <select asp-for="VendorId" required>
                <option value="">— Select vendor —</option>
                @foreach (var v in vendors!) { <option value="@v.Id">@v.Name</option> }
            </select>
        </div>
    </div>

    <table class="items-table">
        <thead><tr><th style="width:35%">Product</th><th style="width:13%">Quantity</th>
            <th style="width:15%">Purchase Price</th><th style="width:15%">Sales Price</th>
            <th style="width:12%" class="num">Line Total</th><th></th></tr></thead>
        <tbody></tbody>
    </table>
    <div style="margin-top:.5rem"><button type="button" class="btn btn-secondary add-row">+ Add Item</button></div>
    <div class="totals">Total: <span class="grand-total" style="margin-left:.5rem">0.00</span></div>

    <div class="actions" style="margin-top:1rem">
        <button class="btn btn-primary">Save Purchase</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
<script>
const products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products,
    new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
LineItems.init(document.getElementById('purchaseForm'), products, { includeSales: true });
</script>
